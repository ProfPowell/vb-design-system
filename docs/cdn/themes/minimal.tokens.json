{
  "color": {
    "seeds": {
      "hue-primary": {
        "$type": "number",
        "$value": 240
      },
      "hue-secondary": {
        "$type": "number",
        "$value": 240
      },
      "hue-accent": {
        "$type": "number",
        "$value": 210
      },
      "lightness-primary": {
        "$type": "number",
        "$value": 35,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-primary": {
        "$type": "number",
        "$value": 0.03
      },
      "lightness-secondary": {
        "$type": "number",
        "$value": 50,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-secondary": {
        "$type": "number",
        "$value": 0.02
      },
      "lightness-accent": {
        "$type": "number",
        "$value": 50,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-accent": {
        "$type": "number",
        "$value": 0.08
      }
    },
    "primary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l + 0.08) c h)"
        }
      }
    },
    "primary-active": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l + 0.12) c h)"
        }
      }
    },
    "primary-subtle": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) 0.97 0.01 h)"
        }
      }
    },
    "secondary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-secondary) calc(l - 0.06) c h)"
        }
      }
    },
    "accent-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-accent) calc(l - 0.06) c h)"
        }
      }
    }
  },
  "typography": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": [
          "system-ui",
          "-apple-system",
          "BlinkMacSystemFont",
          "Segoe UI",
          "sans-serif"
        ]
      }
    },
    "lineHeight": {
      "normal": {
        "$type": "number",
        "$value": 1.6
      },
      "relaxed": {
        "$type": "number",
        "$value": 1.75
      }
    },
    "letterSpacing": {
      "normal": {
        "$type": "dimension",
        "$value": {
          "value": 0.01,
          "unit": "rem"
        },
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "em"
          }
        }
      }
    }
  },
  "border": {
    "radius": {
      "xs": {
        "$type": "dimension",
        "$value": {
          "value": 0,
          "unit": "px"
        }
      },
      "s": {
        "$type": "dimension",
        "$value": {
          "value": 0.125,
          "unit": "rem"
        }
      },
      "m": {
        "$type": "dimension",
        "$value": {
          "value": 0.25,
          "unit": "rem"
        }
      },
      "l": {
        "$type": "dimension",
        "$value": {
          "value": 0.375,
          "unit": "rem"
        }
      },
      "xl": {
        "$type": "dimension",
        "$value": {
          "value": 0.5,
          "unit": "rem"
        }
      },
      "2xl": {
        "$type": "dimension",
        "$value": {
          "value": 0.75,
          "unit": "rem"
        }
      },
      "full": {
        "$type": "dimension",
        "$value": {
          "value": 9999,
          "unit": "px"
        }
      }
    },
    "width": {
      "thin": {
        "$type": "dimension",
        "$value": {
          "value": 1,
          "unit": "px"
        }
      },
      "medium": {
        "$type": "dimension",
        "$value": {
          "value": 1,
          "unit": "px"
        }
      }
    }
  },
  "effect": {
    "shadow": {
      "xs": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 0,
            "unit": "px"
          },
          "blur": {
            "value": 0,
            "unit": "px"
          },
          "color": {
            "colorSpace": "srgb",
            "components": [
              0,
              0,
              0
            ]
          }
        },
        "$extensions": {
          "com.vanilla-breeze": {
            "literal": "none"
          }
        }
      },
      "sm": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 1,
            "unit": "px"
          },
          "blur": {
            "value": 2,
            "unit": "px"
          },
          "color": {
            "colorSpace": "oklch",
            "components": [
              0,
              0,
              0
            ],
            "alpha": 0.03
          },
          "spread": {
            "value": 0,
            "unit": "px"
          }
        }
      },
      "md": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 2,
            "unit": "px"
          },
          "blur": {
            "value": 4,
            "unit": "px"
          },
          "color": {
            "colorSpace": "oklch",
            "components": [
              0,
              0,
              0
            ],
            "alpha": 0.04
          },
          "spread": {
            "value": 0,
            "unit": "px"
          }
        }
      },
      "lg": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 4,
            "unit": "px"
          },
          "blur": {
            "value": 8,
            "unit": "px"
          },
          "color": {
            "colorSpace": "oklch",
            "components": [
              0,
              0,
              0
            ],
            "alpha": 0.05
          },
          "spread": {
            "value": 0,
            "unit": "px"
          }
        }
      },
      "xl": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 8,
            "unit": "px"
          },
          "blur": {
            "value": 16,
            "unit": "px"
          },
          "color": {
            "colorSpace": "oklch",
            "components": [
              0,
              0,
              0
            ],
            "alpha": 0.06
          },
          "spread": {
            "value": 0,
            "unit": "px"
          }
        }
      },
      "2xl": {
        "$type": "shadow",
        "$value": {
          "offsetX": {
            "value": 0,
            "unit": "px"
          },
          "offsetY": {
            "value": 12,
            "unit": "px"
          },
          "blur": {
            "value": 24,
            "unit": "px"
          },
          "color": {
            "colorSpace": "oklch",
            "components": [
              0,
              0,
              0
            ],
            "alpha": 0.08
          },
          "spread": {
            "value": 0,
            "unit": "px"
          }
        }
      }
    }
  },
  "motion": {
    "duration": {
      "instant": {
        "$type": "duration",
        "$value": {
          "value": 0,
          "unit": "ms"
        }
      },
      "fast": {
        "$type": "duration",
        "$value": {
          "value": 75,
          "unit": "ms"
        }
      },
      "normal": {
        "$type": "duration",
        "$value": {
          "value": 120,
          "unit": "ms"
        }
      },
      "slow": {
        "$type": "duration",
        "$value": {
          "value": 200,
          "unit": "ms"
        }
      },
      "slower": {
        "$type": "duration",
        "$value": {
          "value": 300,
          "unit": "ms"
        }
      }
    },
    "easing": {
      "default": {
        "$type": "cubicBezier",
        "$value": [
          0.25,
          0.1,
          0.25,
          1
        ]
      },
      "out": {
        "$type": "cubicBezier",
        "$value": [
          0.25,
          0.1,
          0.25,
          1
        ]
      }
    }
  },
  "$extensions": {
    "com.vanilla-breeze": {
      "spec": "2025.10",
      "vbVersion": "0.1.4",
      "seedDerivation": true
    }
  }
}
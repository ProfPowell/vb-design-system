  "typography": {
    "family": {
      "sans": {
        "$type": "fontFamily",
        "$value": [
          "system-ui",
          "-apple-system",
          "Segoe UI",
          "Roboto",
          "sans-serif"
        ]
      },
      "mono": {
        "$type": "fontFamily",
        "$value": [
          "SF Mono",
          "Cascadia Code",
          "JetBrains Mono",
          "Consolas",
          "monospace"
        ]
      }
    },
    "lineHeight": {
      "normal": {
        "$type": "number",
        "$value": 1.55
      },
      "tight": {
        "$type": "number",
        "$value": 1.15
      }
    }
  },
  "border": {
    "radius": {
      "xs": {
        "$type": "dimension",
        "$value": {
          "value": 2,
          "unit": "px"
        }
      },
      "s": {
        "$type": "dimension",
        "$value": {
          "value": 4,
          "unit": "px"
        }

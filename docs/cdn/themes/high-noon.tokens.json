      "normal": {
        "$type": "duration",
        "$value": {
          "value": 200,
          "unit": "ms"
        }
      },
      "slow": {
        "$type": "duration",
        "$value": {
          "value": 300,
          "unit": "ms"
        }
      }
    },
    "easing": {
      "default": {
        "$type": "cubicBezier",
        "$value": [
          0.25,
          0.46,
          0.45,
          0.94
        ]
      },
      "out": {
        "$type": "cubicBezier",
        "$value": [
          0,
          0,
          0.2,
          1
        ]
      }
    }
  },
  "$extensions": {
    "com.vanilla-breeze": {
      "spec": "2025.10",
      "vbVersion": "0.1.4",
      "unmapped": [
        "--theme-border-style",
        "--theme-icon-set"
      ]
    }
  }

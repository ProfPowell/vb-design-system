{
  "color": {
    "seeds": {
      "hue-primary": {
        "$type": "number",
        "$value": 220
      },
      "hue-secondary": {
        "$type": "number",
        "$value": 200
      },
      "hue-accent": {
        "$type": "number",
        "$value": 35
      },
      "lightness-primary": {
        "$type": "number",
        "$value": 40,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-primary": {
        "$type": "number",
        "$value": 0.12
      },
      "lightness-secondary": {
        "$type": "number",
        "$value": 45,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-secondary": {
        "$type": "number",
        "$value": 0.08
      },
      "lightness-accent": {
        "$type": "number",
        "$value": 60,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-accent": {
        "$type": "number",
        "$value": 0.14
      }
    },
    "primary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l + 0.08) calc(c + 0.02) h)"
        }
      }
    },
    "primary-active": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l + 0.12) c h)"
        }
      }
    },
    "primary-subtle": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) 0.96 0.03 h)"
        }
      }
    },
    "secondary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-secondary) calc(l - 0.06) c h)"
        }
      }
    },
    "accent-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-accent) calc(l - 0.06) c h)"
        }
      }
    }

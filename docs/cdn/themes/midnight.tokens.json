    "easing": {
      "default": {
        "$type": "cubicBezier",
        "$value": [
          0.4,
          0,
          0.2,
          1
        ]
      },
      "out": {
        "$type": "cubicBezier",
        "$value": [
          0,
          0,
          0.2,
          1
        ]
      }
    }
  },
  "$extensions": {
    "com.vanilla-breeze": {
      "spec": "2025.10",
      "vbVersion": "0.1.4",
      "unmapped": [
        "--theme-border-style",
        "--theme-icon-set",
        "--page-bg-gradient"
      ]
    }

{
  "color": {
    "seeds": {
      "hue-primary": {
        "$type": "number",
        "$value": 270
      },
      "hue-secondary": {
        "$type": "number",
        "$value": 220
      },
      "hue-accent": {
        "$type": "number",
        "$value": 45
      },
      "lightness-primary": {
        "$type": "number",
        "$value": 55,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-primary": {
        "$type": "number",
        "$value": 0.22
      },
      "lightness-secondary": {
        "$type": "number",
        "$value": 50,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-secondary": {
        "$type": "number",
        "$value": 0.12
      },
      "lightness-accent": {
        "$type": "number",
        "$value": 75,
        "$extensions": {
          "com.vanilla-breeze": {
            "unit": "%"
          }
        }
      },
      "chroma-accent": {
        "$type": "number",
        "$value": 0.18
      }
    },
    "primary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l - 0.06) calc(c + 0.02) h)"
        }
      }
    },
    "primary-active": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) calc(l - 0.10) c h)"
        }
      }
    },
    "primary-subtle": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-primary) 0.96 0.04 h)"
        }
      }
    },
    "secondary-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-secondary) calc(l - 0.06) c h)"
        }
      }
    },
    "accent-hover": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ]
      },
      "$extensions": {
        "com.vanilla-breeze": {
          "expression": "oklch(from var(--color-accent) calc(l - 0.06) c h)"
        }
      }
    }
  },

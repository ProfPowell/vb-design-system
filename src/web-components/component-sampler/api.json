{
  "$schema": "../../../schemas/api.schema.json",
  "element": "component-sampler",
  "type": "web-component",
  "description": "Themed UI element preview grid. Renders native HTML elements styled by the active VB theme.",
  "htmlvalidate": {
    "flow": true,
    "permittedContent": ["@flow"]
  },
  "attributes": [
    { "name": "components", "kind": "host-api", "purpose": "config", "type": "string",  "default": "button,input,select,checkbox,radio,badge,progress", "description": "Comma-separated component types to render" },
    { "name": "label",      "kind": "host-api", "purpose": "config", "type": "string",  "description": "Optional heading label" },
    { "name": "compact",    "kind": "host-api", "purpose": "config", "type": "boolean", "description": "Reduced spacing variant" }
  ]
}
